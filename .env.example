# Web search API (required)
TAVILY_API_KEY=your_tavily_key_here

# Triage filter API — free tier at console.groq.com (required)
GROQ_API_KEY=your_groq_key_here

# Telegram push notifications (optional — results print to console if omitted)
TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# DeepSeek cloud analysis (optional — only needed if you choose DeepSeek over Ollama during setup)
DEEPSEEK_API_KEY=your_deepseek_key_here

# Curated Italian tech companies list (optional — GitHub raw URL to companies JSON)
COMPANIES_LIST_URL=your_companies_list_url_here
